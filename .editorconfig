# top-most EditorConfig file
root = true

# All files
[*]
charset = utf-8
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

# C# files
#[*.cs]
#indent_size = 4

# Suppress VSTHRD200 (Use Async suffix for async methods) in Controller files
[*Controller.cs]
dotnet_diagnostic.VSTHRD200.severity = none

[**/Migrations/*.cs]
generated_code = true
